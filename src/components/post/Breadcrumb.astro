---
import { currentLocale, getT } from "@/i18n";
import { toCategoryHref } from "@/toolkit/posts/url";

interface Props {
  categories?: string[];
  isHome?: boolean;
}

const { categories = [], isHome = true } = Astro.props;
const t = getT(currentLocale);

const siteBase = Astro.site ?? Astro.url;
const toAbsoluteUrl = (href: string) => new URL(href, siteBase).toString();

const shouldUseStructuredData = categories.length > 0;

const breadcrumbItems = [
  {
    name: t("common.home"),
    href: "/",
    absoluteHref: toAbsoluteUrl("/"),
    title: t("common.home"),
  },
  ...categories.map((cat) => {
    const href = toCategoryHref(cat);

    return {
      name: cat,
      href,
      absoluteHref: toAbsoluteUrl(href),
      title: `${t("common.in")} ${cat}`,
    };
  }),
];
---

<div
  class="breadcrumb"
  itemscope={shouldUseStructuredData ? true : undefined}
  itemtype={
    shouldUseStructuredData
      ? "https://schema.org/BreadcrumbList"
      : undefined
  }
>
  {
    breadcrumbItems.map((item, index) => {
      const isFirst = index === 0;
      const isLast = index === breadcrumbItems.length - 1;

      return (
        <>
          {isFirst ? (
            <i class="ic i-ri-home-fill" />
          ) : (
            <i class="ic i-ri-arrow-right-s-line" />
          )}

          {shouldUseStructuredData ? (
            <span
              class={isLast && isHome ? "current" : undefined}
              itemprop="itemListElement"
              itemscope
              itemtype="https://schema.org/ListItem"
            >
              <a
                href={item.href}
                itemprop="item"
                itemscope
                itemtype="https://schema.org/WebPage"
                itemid={item.absoluteHref}
                rel={isFirst ? undefined : "index"}
                title={item.title}
              >
                <meta itemprop="url" content={item.absoluteHref} />
                <span itemprop="name">{item.name}</span>
              </a>
              <meta itemprop="position" content={String(index + 1)} />
            </span>
          ) : (
            <span class={isLast && isHome ? "current" : undefined}>
              <a href={item.href} title={item.title}>
                {item.name}
              </a>
            </span>
          )}
        </>
      );
    })
  }
</div>